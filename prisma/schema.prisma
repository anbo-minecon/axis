// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────

model Usuario {
  id             String       @id @default(cuid())
  nombre         String
  email          String       @unique
  emailVerified  DateTime?
  passwordHash   String?
  imagen         String?

  // Campos de perfil extendido (DB anterior)
  documento      String?      // número de documento de identidad
  telefono       String?
  departamento   String?
  municipio      String?

  // Campos académicos
  colegio        String?
  grado          Int?         // 9, 10, 11
  ciudad         String?

  rol            Rol          @default(ESTUDIANTE)
  planId         String?
  plan           Plan?        @relation(fields: [planId], references: [id])

  // Grupo de estudio asignado
  grupoId        String?
  grupo          Grupo?       @relation(fields: [grupoId], references: [id])

  // Grupos que dirige como docente
  gruposDocencia Grupo[]      @relation("GrupoDocente")

  simulacros     Simulacro[]
  intentos       Intento[]
  suscripcion    Suscripcion?
  developerCred  DeveloperCredential?
  auditLogs      AuditLog[]
  resultados     ResultadoSimulacro[]
  materiales     Material[]      @relation("CreadorMaterial")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversacionesA  Conversacion[]  @relation("ConvParticipanteA")
  conversacionesB  Conversacion[]  @relation("ConvParticipanteB")
   mensajesEnviados Mensaje[]       @relation("MensajesEnviados")

  @@map("usuarios")
}

enum Rol {
  ESTUDIANTE
  DOCENTE
  ADMIN
  DEVELOPER
}

// ─── GRUPOS ───────────────────────────────────────────────────────────────────

model Grupo {
  id           String    @id @default(cuid())
  nombre       String
  descripcion  String?
  departamento String?
  municipio    String?

  // Docente responsable del grupo
  docenteId    String?
  docente      Usuario?  @relation("GrupoDocente", fields: [docenteId], references: [id])

  // Estudiantes del grupo
  estudiantes  Usuario[]

  // Horario / info adicional
  horario      String?   // ej: "Sábados 8am - 12pm"
  activo       Boolean   @default(true)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("grupos")
}

// ─── ÁREAS Y PREGUNTAS ────────────────────────────────────────────────────────

model Area {
  id          String      @id @default(cuid())
  nombre      String      @unique  // "Matemáticas", "Lectura Crítica", etc.
  descripcion String?
  color       String?     // color hex para UI
  icono       String?
  preguntas   Pregunta[]

  @@map("areas")
}

model Pregunta {
  id                String             @id @default(cuid())
  enunciado         String
  imagenUrl         String?
  nivelDificultad   Int                @default(1) // 1=fácil, 2=medio, 3=difícil
  anioReferencia    Int?
  activa            Boolean            @default(true)
  areaId            String
  area              Area               @relation(fields: [areaId], references: [id])
  opciones          OpcionRespuesta[]
  respuestasUsuario RespuestaUsuario[]

  @@map("preguntas")
}

model OpcionRespuesta {
  id         String             @id @default(cuid())
  texto      String
  esCorrecta Boolean            @default(false)
  preguntaId String
  pregunta   Pregunta           @relation(fields: [preguntaId], references: [id])
  respuestas RespuestaUsuario[]

  @@map("opciones_respuesta")
}

// ─── SIMULACROS ───────────────────────────────────────────────────────────────

model Simulacro {
  id              String             @id @default(cuid())
  usuarioId       String
  usuario         Usuario            @relation(fields: [usuarioId], references: [id])
  tipo            TipoSimulacro      @default(COMPLETO)
  estado          EstadoSimulacro    @default(EN_PROGRESO)
  puntajeTotal    Float?
  fechaInicio     DateTime           @default(now())
  fechaFin        DateTime?
  duracionMin     Int                @default(210) // minutos
  totalPreguntas  Int                @default(45) // número de preguntas del simulacro
  respuestas      RespuestaUsuario[]
  intentos        Intento[]

  @@map("simulacros")
}

// ─── INTENTOS ─────────────────────────────────────────────────────────────────

model Intento {
  id              String             @id @default(cuid())
  usuarioId       String
  usuario         Usuario            @relation(fields: [usuarioId], references: [id])
  simulacroId     String?
  simulacro       Simulacro?         @relation(fields: [simulacroId], references: [id])
  estado          String             @default("en_progreso") // en_progreso, completado, abandonado
  puntaje         Float?
  aciertos        Int?
  totalPreguntas  Int?
  fechaInicio     DateTime           @default(now())
  fechaFin        DateTime?
  duracionMin     Int?
  respuestasUser  RespuestaIntento[]

  @@map("intentos")
  @@index([usuarioId])
  @@index([estado])
  @@index([fechaInicio])
}

model RespuestaIntento {
  id               String    @id @default(cuid())
  intentoId        String
  intento          Intento   @relation(fields: [intentoId], references: [id], onDelete: Cascade)
  preguntaId       String
  opcionId         String?
  esCorrecta       Boolean?
  tiempoSegundos   Int?
  respondidaEn     DateTime  @default(now())

  @@map("respuestas_intento")
  @@index([intentoId])
}

enum TipoSimulacro {
  COMPLETO
  POR_AREA
  PRACTICA_RAPIDA
}

enum EstadoSimulacro {
  EN_PROGRESO
  FINALIZADO
  ABANDONADO
}

model RespuestaUsuario {
  id                   String           @id @default(cuid())
  simulacroId          String
  simulacro            Simulacro        @relation(fields: [simulacroId], references: [id])
  preguntaId           String
  pregunta             Pregunta         @relation(fields: [preguntaId], references: [id])
  opcionSeleccionadaId String?
  opcionSeleccionada   OpcionRespuesta? @relation(fields: [opcionSeleccionadaId], references: [id])
  esCorrecta           Boolean?
  tiempoSegundos       Int?
  respondidaEn         DateTime         @default(now())

  @@map("respuestas_usuario")
}

// ─── PLANES Y SUSCRIPCIONES ───────────────────────────────────────────────────

model Plan {
  id              String        @id @default(cuid())
  nombre          String        @unique // "Básico", "Pro", "Institucional"
  descripcion     String?
  precio          Float
  duracionDias    Int
  simulacrosMax   Int           @default(-1) // -1 = ilimitados
  caracteristicas String[]
  activo          Boolean       @default(true)
  usuarios        Usuario[]
  suscripciones   Suscripcion[]

  @@map("planes")
}

model Suscripcion {
  id          String   @id @default(cuid())
  usuarioId   String   @unique
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  fechaInicio DateTime @default(now())
  fechaFin    DateTime
  activa      Boolean  @default(true)

  @@map("suscripciones")
}

// ─── DEVELOPER ACCESS ──────────────────────────────────────────────────────────

model DeveloperCredential {
  id            String    @id @default(cuid())
  usuarioId     String    @unique
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  passwordHash  String
  tokenSecret   String    @unique
  activo        Boolean   @default(true)
  ultimoAcceso  DateTime?
  direccionIP   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("developer_credentials")
}

// ─── AUDIT & LOGS ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String    @id @default(cuid())
  usuarioId   String?   // null si es acción del sistema
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  accion      String    // ej: CREAR_USUARIO, ELIMINAR_GRUPO, CAMBIAR_PLAN
  recurso     String    // ej: usuario, grupo, plan
  recursoId   String?
  cambios     String?   // JSON con antes/después si aplica
  resultado   String    @default("EXITOSO") // EXITOSO, ERROR
  mensaje     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@map("audit_logs")
  @@index([createdAt])
  @@index([usuarioId])
}

model SystemLog {
  id        String    @id @default(cuid())
  nivel     String    @default("INFO") // INFO, WARN, ERROR, CRITICAL
  componente String   // ej: AUTH, DATABASE, API, BACKUP
  mensaje   String
  detalles  String?   // JSON con contexto adicional
  stack     String?   // stack trace si es error
  createdAt DateTime  @default(now())

  @@map("system_logs")
  @@index([createdAt])
  @@index([nivel])
}



model BackupLog {
  id          String    @id @default(cuid())
  tipo        String    // FULL, INCREMENTAL
  estado      String    @default("INICIADO") // INICIADO, EN_PROGRESO, COMPLETADO, ERROR
  tamanio     Int?      // tamaño en MB
  ubicacion   String?   // path o URL del backup
  error       String?
  duracionMs  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("backup_logs")
  @@index([createdAt])
}

model IntegrationLog {
  id              String    @id @default(cuid())
  nombre          String    // ej: Google Auth, Stripe Payment
  estado          String    @default("CONECTADO") // CONECTADO, ERROR, DEGRADED
  ultimaVerif     DateTime?
  ultimoError     String?
  responseTime    Int?      // ms
  requestsHoy     Int?
  tasaError       Float?    // porcentaje
  detalles        String?   // JSON con info específica
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("integration_logs")
  @@index([createdAt])
}

// ─── AGREGAR AL FINAL DE prisma/schema.prisma ────────────────────────────────
// Correr después: npx prisma migrate dev --name add_examenes_template

model ExamenTemplate {
  id              String           @id @default(cuid())
  nombre          String
  materia         String
  totalPreguntas  Int              @default(50)
  tiempoMin       Int              @default(120)
  estado          EstadoExamen     @default(BORRADOR)
  creadoPorId     String           // id del admin que lo creó
  claves          ClaveExamen[]
  resultados      ResultadoSimulacro[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("examenes_template")
}

model ClaveExamen {
  id             String         @id @default(cuid())
  examenId       String
  examen         ExamenTemplate @relation(fields: [examenId], references: [id], onDelete: Cascade)
  numeroPregunta Int
  respuesta      String         // "A", "B", "C" o "D"

  @@unique([examenId, numeroPregunta])
  @@map("claves_examen")
}

enum EstadoExamen {
  BORRADOR
  PUBLICADO
  ARCHIVADO
}



// ─── AGREGAR AL FINAL DE prisma/schema.prisma ────────────────────────────────
// Agregar también fechaDisponible a ExamenTemplate:
//
//   model ExamenTemplate {
//     ...campos existentes...
//     fechaDisponible DateTime?          // null = disponible inmediatamente
//   }
//
// Luego correr: npx prisma migrate dev --name add_resultados_simulacro

model ResultadoSimulacro {
  id           String   @id @default(cuid())
  estudianteId String
  examenId     String
  respuestas   Json     // { "1": "A", "2": "B", "3": "C", ... }
  puntaje      Int      // respuestas correctas
  total        Int      // total de claves definidas
  tiempoUsado  Int      // segundos usados
  completadoEn DateTime @default(now())

  estudiante Usuario        @relation(fields: [estudianteId], references: [id])
  examen     ExamenTemplate @relation(fields: [examenId], references: [id])

  @@unique([estudianteId, examenId])   // un intento por estudiante por examen
  @@map("resultados_simulacro")
}

// ─── AGREGAR AL FINAL DE prisma/schema.prisma ────────────────────────────────
// npx prisma migrate dev --name add_material_estudio

model Material {
  id          String        @id @default(cuid())
  titulo      String
  descripcion String?
  tipo        TipoMaterial  // PDF | VIDEO
  url         String
  materia     String?       // opcional: "Matemáticas", "Inglés", etc.
  gratis      Boolean       @default(true) // siempre true por ahora, para futuro
  activo      Boolean       @default(true)
  orden       Int           @default(0)    // para ordenar manualmente
  creadoPorId String
  creadoPor   Usuario       @relation("CreadorMaterial", fields: [creadoPorId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("materiales")
}

enum TipoMaterial {
  PDF
  VIDEO
}

model Conversacion {
  id               String    @id @default(cuid())
  participanteAId  String                          // siempre el de menor rol o el que inicia
  participanteBId  String
  participanteA    Usuario   @relation("ConvParticipanteA", fields: [participanteAId], references: [id])
  participanteB    Usuario   @relation("ConvParticipanteB", fields: [participanteBId], references: [id])
  ultimoMensaje    String?
  ultimoMensajeEn  DateTime?
  noLeidosA        Int       @default(0)           // mensajes no leídos para participanteA
  noLeidosB        Int       @default(0)           // mensajes no leídos para participanteB
  creadaEn         DateTime  @default(now())
  mensajes         Mensaje[]

  @@unique([participanteAId, participanteBId])
  @@index([participanteAId])
  @@index([participanteBId])
  @@map("conversaciones")
}

model Mensaje {
  id             String       @id @default(cuid())
  conversacionId String
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  remitenteId    String
  remitente      Usuario      @relation("MensajesEnviados", fields: [remitenteId], references: [id])
  contenido      String
  leido          Boolean      @default(false)
  creadoEn       DateTime     @default(now())

  @@map("mensajes")
  @@index([conversacionId, creadoEn])
}



// ─── AGREGAR AL FINAL DE prisma/schema.prisma ────────────────────────────────
// npx prisma migrate dev --name add_anuncios
//
// DIMENSIÓN RECOMENDADA PARA LAS IMÁGENES: 1280 x 720 px (proporción 16:9)
// Formatos aceptados: JPG, PNG, WebP
// Puedes alojar las imágenes en: Google Drive (compartido públicamente),
// Imgur, Cloudinary, o cualquier CDN que devuelva una URL directa de imagen.

model Anuncio {
  id          String   @id @default(cuid())
  titulo      String                        // texto alternativo / descripción interna
  imagenUrl   String                        // URL directa de la imagen (1200x400)
  linkUrl     String?                       // URL destino al hacer click (opcional)
  activo      Boolean  @default(true)
  orden       Int      @default(0)          // menor número = aparece primero
  creadoPorId String
  creadoEn    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("anuncios")
}
