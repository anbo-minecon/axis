// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIOS ────────────────────────────────────────────────────────────────

model Usuario {
  id             String       @id @default(cuid())
  nombre         String
  email          String       @unique
  emailVerified  DateTime?
  passwordHash   String?
  imagen         String?

  // Campos de perfil extendido (DB anterior)
  documento      String?      // número de documento de identidad
  telefono       String?
  departamento   String?
  municipio      String?

  // Campos académicos
  colegio        String?
  grado          Int?         // 9, 10, 11
  ciudad         String?

  rol            Rol          @default(ESTUDIANTE)
  planId         String?
  plan           Plan?        @relation(fields: [planId], references: [id])

  // Grupo de estudio asignado
  grupoId        String?
  grupo          Grupo?       @relation(fields: [grupoId], references: [id])

  // Grupos que dirige como docente
  gruposDocencia Grupo[]      @relation("GrupoDocente")

  simulacros     Simulacro[]
  intentos       Intento[]
  suscripcion    Suscripcion?
  developerCred  DeveloperCredential?
  auditLogs      AuditLog[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("usuarios")
}

enum Rol {
  ESTUDIANTE
  DOCENTE
  ADMIN
  DEVELOPER
}

// ─── GRUPOS ───────────────────────────────────────────────────────────────────

model Grupo {
  id           String    @id @default(cuid())
  nombre       String
  descripcion  String?
  departamento String?
  municipio    String?

  // Docente responsable del grupo
  docenteId    String?
  docente      Usuario?  @relation("GrupoDocente", fields: [docenteId], references: [id])

  // Estudiantes del grupo
  estudiantes  Usuario[]

  // Horario / info adicional
  horario      String?   // ej: "Sábados 8am - 12pm"
  activo       Boolean   @default(true)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("grupos")
}

// ─── ÁREAS Y PREGUNTAS ────────────────────────────────────────────────────────

model Area {
  id          String      @id @default(cuid())
  nombre      String      @unique  // "Matemáticas", "Lectura Crítica", etc.
  descripcion String?
  color       String?     // color hex para UI
  icono       String?
  preguntas   Pregunta[]

  @@map("areas")
}

model Pregunta {
  id                String             @id @default(cuid())
  enunciado         String
  imagenUrl         String?
  nivelDificultad   Int                @default(1) // 1=fácil, 2=medio, 3=difícil
  anioReferencia    Int?
  activa            Boolean            @default(true)
  areaId            String
  area              Area               @relation(fields: [areaId], references: [id])
  opciones          OpcionRespuesta[]
  respuestasUsuario RespuestaUsuario[]

  @@map("preguntas")
}

model OpcionRespuesta {
  id         String             @id @default(cuid())
  texto      String
  esCorrecta Boolean            @default(false)
  preguntaId String
  pregunta   Pregunta           @relation(fields: [preguntaId], references: [id])
  respuestas RespuestaUsuario[]

  @@map("opciones_respuesta")
}

// ─── SIMULACROS ───────────────────────────────────────────────────────────────

model Simulacro {
  id              String             @id @default(cuid())
  usuarioId       String
  usuario         Usuario            @relation(fields: [usuarioId], references: [id])
  tipo            TipoSimulacro      @default(COMPLETO)
  estado          EstadoSimulacro    @default(EN_PROGRESO)
  puntajeTotal    Float?
  fechaInicio     DateTime           @default(now())
  fechaFin        DateTime?
  duracionMin     Int                @default(210) // minutos
  totalPreguntas  Int                @default(45) // número de preguntas del simulacro
  respuestas      RespuestaUsuario[]
  intentos        Intento[]

  @@map("simulacros")
}

// ─── INTENTOS ─────────────────────────────────────────────────────────────────

model Intento {
  id              String             @id @default(cuid())
  usuarioId       String
  usuario         Usuario            @relation(fields: [usuarioId], references: [id])
  simulacroId     String?
  simulacro       Simulacro?         @relation(fields: [simulacroId], references: [id])
  estado          String             @default("en_progreso") // en_progreso, completado, abandonado
  puntaje         Float?
  aciertos        Int?
  totalPreguntas  Int?
  fechaInicio     DateTime           @default(now())
  fechaFin        DateTime?
  duracionMin     Int?
  respuestasUser  RespuestaIntento[]

  @@map("intentos")
  @@index([usuarioId])
  @@index([estado])
  @@index([fechaInicio])
}

model RespuestaIntento {
  id               String    @id @default(cuid())
  intentoId        String
  intento          Intento   @relation(fields: [intentoId], references: [id], onDelete: Cascade)
  preguntaId       String
  opcionId         String?
  esCorrecta       Boolean?
  tiempoSegundos   Int?
  respondidaEn     DateTime  @default(now())

  @@map("respuestas_intento")
  @@index([intentoId])
}

enum TipoSimulacro {
  COMPLETO
  POR_AREA
  PRACTICA_RAPIDA
}

enum EstadoSimulacro {
  EN_PROGRESO
  FINALIZADO
  ABANDONADO
}

model RespuestaUsuario {
  id                   String           @id @default(cuid())
  simulacroId          String
  simulacro            Simulacro        @relation(fields: [simulacroId], references: [id])
  preguntaId           String
  pregunta             Pregunta         @relation(fields: [preguntaId], references: [id])
  opcionSeleccionadaId String?
  opcionSeleccionada   OpcionRespuesta? @relation(fields: [opcionSeleccionadaId], references: [id])
  esCorrecta           Boolean?
  tiempoSegundos       Int?
  respondidaEn         DateTime         @default(now())

  @@map("respuestas_usuario")
}

// ─── PLANES Y SUSCRIPCIONES ───────────────────────────────────────────────────

model Plan {
  id              String        @id @default(cuid())
  nombre          String        @unique // "Básico", "Pro", "Institucional"
  descripcion     String?
  precio          Float
  duracionDias    Int
  simulacrosMax   Int           @default(-1) // -1 = ilimitados
  caracteristicas String[]
  activo          Boolean       @default(true)
  usuarios        Usuario[]
  suscripciones   Suscripcion[]

  @@map("planes")
}

model Suscripcion {
  id          String   @id @default(cuid())
  usuarioId   String   @unique
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  fechaInicio DateTime @default(now())
  fechaFin    DateTime
  activa      Boolean  @default(true)

  @@map("suscripciones")
}

// ─── DEVELOPER ACCESS ──────────────────────────────────────────────────────────

model DeveloperCredential {
  id            String    @id @default(cuid())
  usuarioId     String    @unique
  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  passwordHash  String
  tokenSecret   String    @unique
  activo        Boolean   @default(true)
  ultimoAcceso  DateTime?
  direccionIP   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("developer_credentials")
}

// ─── AUDIT & LOGS ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String    @id @default(cuid())
  usuarioId   String?   // null si es acción del sistema
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  accion      String    // ej: CREAR_USUARIO, ELIMINAR_GRUPO, CAMBIAR_PLAN
  recurso     String    // ej: usuario, grupo, plan
  recursoId   String?
  cambios     String?   // JSON con antes/después si aplica
  resultado   String    @default("EXITOSO") // EXITOSO, ERROR
  mensaje     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  @@map("audit_logs")
  @@index([createdAt])
  @@index([usuarioId])
}

model SystemLog {
  id        String    @id @default(cuid())
  nivel     String    @default("INFO") // INFO, WARN, ERROR, CRITICAL
  componente String   // ej: AUTH, DATABASE, API, BACKUP
  mensaje   String
  detalles  String?   // JSON con contexto adicional
  stack     String?   // stack trace si es error
  createdAt DateTime  @default(now())

  @@map("system_logs")
  @@index([createdAt])
  @@index([nivel])
}

model BackupLog {
  id          String    @id @default(cuid())
  tipo        String    // FULL, INCREMENTAL
  estado      String    @default("INICIADO") // INICIADO, EN_PROGRESO, COMPLETADO, ERROR
  tamanio     Int?      // tamaño en MB
  ubicacion   String?   // path o URL del backup
  error       String?
  duracionMs  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("backup_logs")
  @@index([createdAt])
}

model IntegrationLog {
  id              String    @id @default(cuid())
  nombre          String    // ej: Google Auth, Stripe Payment
  estado          String    @default("CONECTADO") // CONECTADO, ERROR, DEGRADED
  ultimaVerif     DateTime?
  ultimoError     String?
  responseTime    Int?      // ms
  requestsHoy     Int?
  tasaError       Float?    // porcentaje
  detalles        String?   // JSON con info específica
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("integration_logs")
  @@index([createdAt])
}
