// prisma/schema.prisma
// VERSIÓN COMPLETA — reemplaza el archivo existente

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USUARIOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id            String    @id @default(cuid())
  nombre        String?   // Opcional para Google OAuth — se completa en /auth/registro-google
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  imagen        String?

  // Perfil extendido
  documento    String?
  telefono     String?
  departamento String?
  municipio    String?

  // Académico
  colegio String?
  grado   Int?
  ciudad  String?

  rol    Rol     @default(ESTUDIANTE)
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  // Grupo
  grupoId        String?
  grupo          Grupo?  @relation(fields: [grupoId], references: [id])
  gruposDocencia Grupo[] @relation("GrupoDocente")

  // ── Relaciones NextAuth (NUEVO — requeridas por PrismaAdapter) ────────────
  accounts Account[]
  sessions Session[]

  //── Relacion con Classroom (NUEVO — para integración con Google Classroom) ────────────
  classroomToken   ClassroomToken?
  classroomClases  ClassroomClase[] @relation("ClaseDocente")

  // ── Relaciones de negocio ─────────────────────────────────────────────────
  simulacros       Simulacro[]
  intentos         Intento[]
  suscripcion      Suscripcion?
  developerCred    DeveloperCredential?
  auditLogs        AuditLog[]
  resultados       ResultadoSimulacro[]
  resultadosSesion ResultadoSesion[]
  materiales       Material[]           @relation("CreadorMaterial")
  conversacionesA  Conversacion[]       @relation("ConvParticipanteA")
  conversacionesB  Conversacion[]       @relation("ConvParticipanteB")
  mensajesEnviados Mensaje[]            @relation("MensajesEnviados")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

enum Rol {
  ESTUDIANTE
  DOCENTE
  ADMIN
  DEVELOPER
}

// ─── NEXTAUTH — Account, Session, VerificationToken ──────────────────────────
// Requeridos por PrismaAdapter para que Google OAuth guarde correctamente
// los tokens y vincule la cuenta Google al Usuario

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── GRUPOS ───────────────────────────────────────────────────────────────────

model Grupo {
  id           String    @id @default(cuid())
  nombre       String
  descripcion  String?
  departamento String?
  municipio    String?
  docenteId    String?
  docente      Usuario?  @relation("GrupoDocente", fields: [docenteId], references: [id])
  estudiantes  Usuario[]
  clases       ClassroomClase[]
  horario      String?
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("grupos")
}

// ─── ÁREAS Y PREGUNTAS ────────────────────────────────────────────────────────

model Area {
  id          String     @id @default(cuid())
  nombre      String     @unique
  descripcion String?
  color       String?
  icono       String?
  preguntas   Pregunta[]

  @@map("areas")
}

model Pregunta {
  id                String             @id @default(cuid())
  enunciado         String
  imagenUrl         String?
  nivelDificultad   Int                @default(1)
  anioReferencia    Int?
  activa            Boolean            @default(true)
  areaId            String
  area              Area               @relation(fields: [areaId], references: [id])
  opciones          OpcionRespuesta[]
  respuestasUsuario RespuestaUsuario[]

  @@map("preguntas")
}

model OpcionRespuesta {
  id         String             @id @default(cuid())
  texto      String
  esCorrecta Boolean            @default(false)
  preguntaId String
  pregunta   Pregunta           @relation(fields: [preguntaId], references: [id])
  respuestas RespuestaUsuario[]

  @@map("opciones_respuesta")
}

// ─── SIMULACROS (modelo legado) ───────────────────────────────────────────────

model Simulacro {
  id             String             @id @default(cuid())
  usuarioId      String
  usuario        Usuario            @relation(fields: [usuarioId], references: [id])
  tipo           TipoSimulacro      @default(COMPLETO)
  estado         EstadoSimulacro    @default(EN_PROGRESO)
  puntajeTotal   Float?
  fechaInicio    DateTime           @default(now())
  fechaFin       DateTime?
  duracionMin    Int                @default(210)
  totalPreguntas Int                @default(45)
  respuestas     RespuestaUsuario[]
  intentos       Intento[]

  @@map("simulacros")
}

model Intento {
  id             String             @id @default(cuid())
  usuarioId      String
  usuario        Usuario            @relation(fields: [usuarioId], references: [id])
  simulacroId    String?
  simulacro      Simulacro?         @relation(fields: [simulacroId], references: [id])
  estado         String             @default("en_progreso")
  puntaje        Float?
  aciertos       Int?
  totalPreguntas Int?
  fechaInicio    DateTime           @default(now())
  fechaFin       DateTime?
  duracionMin    Int?
  respuestasUser RespuestaIntento[]

  @@map("intentos")
  @@index([usuarioId])
  @@index([estado])
  @@index([fechaInicio])
}

model RespuestaIntento {
  id             String   @id @default(cuid())
  intentoId      String
  intento        Intento  @relation(fields: [intentoId], references: [id], onDelete: Cascade)
  preguntaId     String
  opcionId       String?
  esCorrecta     Boolean?
  tiempoSegundos Int?
  respondidaEn   DateTime @default(now())

  @@map("respuestas_intento")
  @@index([intentoId])
}

enum TipoSimulacro {
  COMPLETO
  POR_AREA
  PRACTICA_RAPIDA
}

enum EstadoSimulacro {
  EN_PROGRESO
  FINALIZADO
  ABANDONADO
}

model RespuestaUsuario {
  id                   String           @id @default(cuid())
  simulacroId          String
  simulacro            Simulacro        @relation(fields: [simulacroId], references: [id])
  preguntaId           String
  pregunta             Pregunta         @relation(fields: [preguntaId], references: [id])
  opcionSeleccionadaId String?
  opcionSeleccionada   OpcionRespuesta? @relation(fields: [opcionSeleccionadaId], references: [id])
  esCorrecta           Boolean?
  tiempoSegundos       Int?
  respondidaEn         DateTime         @default(now())

  @@map("respuestas_usuario")
}

// ─── PLANES Y SUSCRIPCIONES ───────────────────────────────────────────────────

model Plan {
  id              String        @id @default(cuid())
  nombre          String        @unique
  descripcion     String?
  precio          Float
  duracionDias    Int
  simulacrosMax   Int           @default(-1)
  caracteristicas String[]
  activo          Boolean       @default(true)
  usuarios        Usuario[]
  suscripciones   Suscripcion[]

  @@map("planes")
}

model Suscripcion {
  id          String   @id @default(cuid())
  usuarioId   String   @unique
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  planId      String
  plan        Plan     @relation(fields: [planId], references: [id])
  fechaInicio DateTime @default(now())
  fechaFin    DateTime
  activa      Boolean  @default(true)

  @@map("suscripciones")
}

// ─── DEVELOPER ACCESS ────────────────────────────────────────────────────────

model DeveloperCredential {
  id           String   @id @default(cuid())
  usuarioId    String   @unique
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("developer_credentials")
}

// ─── LOGS ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  // usuarioId es nullable para permitir logs de acciones sin usuario autenticado
  usuarioId  String?
  usuario    Usuario? @relation(fields: [usuarioId], references: [id])
  accion     String
  recurso    String?
  recursoId  String?
  resultado  String   @default("EXITOSO")
  mensaje    String?
  ip         String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
  @@index([createdAt])
  @@index([usuarioId])
}

model SystemLog {
  id         String   @id @default(cuid())
  nivel      String   @default("INFO")
  componente String
  mensaje    String
  detalles   String?
  stack      String?
  createdAt  DateTime @default(now())

  @@map("system_logs")
  @@index([createdAt])
  @@index([nivel])
}

model BackupLog {
  id         String   @id @default(cuid())
  tipo       String
  estado     String   @default("INICIADO")
  tamanio    Int?
  ubicacion  String?
  error      String?
  duracionMs Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("backup_logs")
  @@index([createdAt])
}

model IntegrationLog {
  id           String    @id @default(cuid())
  nombre       String
  estado       String    @default("CONECTADO")
  ultimaVerif  DateTime?
  ultimoError  String?
  responseTime Int?
  requestsHoy  Int?
  tasaError    Float?
  detalles     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("integration_logs")
  @@index([createdAt])
}

// ─── EXÁMENES TEMPLATE (sistema nuevo con TRI) ────────────────────────────────

model ExamenTemplate {
  id             String  @id @default(cuid())
  nombre         String
  materia        String
  totalPreguntas Int     @default(50)
  tiempoMin      Int     @default(120)

  tieneSesiones Boolean        @default(false)
  sesiones      SesionExamen[]

  fechaDisponible DateTime?
  fechaCierre     DateTime?

  estado       EstadoExamen @default(BORRADOR)
  triCalculado Boolean      @default(false)

  creadoPorId      String
  claves           ClaveExamen[]
  resultados       ResultadoSimulacro[]
  resultadosSesion ResultadoSesion[]
  pesos            PesosPregunta[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("examenes_template")
}

model SesionExamen {
  id         String            @id @default(cuid())
  examenId   String
  examen     ExamenTemplate    @relation(fields: [examenId], references: [id], onDelete: Cascade)
  numero     Int
  nombre     String
  tiempoMin  Int               @default(60)
  claves     ClaveExamen[]
  resultados ResultadoSesion[]
  pesos      PesosPregunta[]

  @@unique([examenId, numero])
  @@map("sesiones_examen")
}

model ClaveExamen {
  id             String         @id @default(cuid())
  examenId       String
  examen         ExamenTemplate @relation(fields: [examenId], references: [id], onDelete: Cascade)
  sesionId       String?
  sesion         SesionExamen?  @relation(fields: [sesionId], references: [id], onDelete: SetNull)
  numeroPregunta Int
  respuesta      String

  @@unique([examenId, numeroPregunta, sesionId])
  @@map("claves_examen")
}

enum EstadoExamen {
  BORRADOR
  PUBLICADO
  CERRADO
  ARCHIVADO
}

// ─── RESULTADOS CON TRI ───────────────────────────────────────────────────────

enum EstadoCalificacion {
  PRELIMINAR
  OFICIAL
}

model ResultadoSesion {
  id                String   @id @default(cuid())
  estudianteId      String
  examenId          String
  sesionId          String
  respuestas        Json
  aciertos          Int      @default(0)
  total             Int
  puntajePreliminar Float    @default(0)
  puntajeTRI        Float?
  tiempoUsado       Int      @default(0)
  completadoEn      DateTime @default(now())

  estudiante Usuario        @relation(fields: [estudianteId], references: [id])
  examen     ExamenTemplate @relation(fields: [examenId], references: [id])
  sesion     SesionExamen   @relation(fields: [sesionId], references: [id])

  @@unique([estudianteId, sesionId])
  @@map("resultados_sesion")
}

model ResultadoSimulacro {
  id                String             @id @default(cuid())
  estudianteId      String
  examenId          String
  respuestas        Json               @default("{}")
  puntaje           Int                @default(0)
  total             Int                @default(0)
  puntajePreliminar Float              @default(0)
  puntajeTRI        Float?
  estadoCalif       EstadoCalificacion @default(PRELIMINAR)
  tiempoUsado       Int                @default(0)
  completadoEn      DateTime           @default(now())

  estudiante Usuario        @relation(fields: [estudianteId], references: [id])
  examen     ExamenTemplate @relation(fields: [examenId], references: [id])

  @@unique([estudianteId, examenId])
  @@map("resultados_simulacro")
}

model PesosPregunta {
  id              String  @id @default(cuid())
  examenId        String
  sesionId        String?
  numeroPregunta  Int
  dificultad      Float
  discriminacion  Float
  pesoNormalizado Float

  examen ExamenTemplate @relation(fields: [examenId], references: [id], onDelete: Cascade)
  sesion SesionExamen?  @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@unique([examenId, numeroPregunta, sesionId])
  @@map("pesos_pregunta")
}

// ─── MATERIALES ───────────────────────────────────────────────────────────────

model Material {
  id          String       @id @default(cuid())
  titulo      String
  descripcion String?
  tipo        TipoMaterial
  url         String
  materia     String?
  gratis      Boolean      @default(true)
  activo      Boolean      @default(true)
  orden       Int          @default(0)
  creadoPorId String
  creadoPor   Usuario      @relation("CreadorMaterial", fields: [creadoPorId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("materiales")
}

enum TipoMaterial {
  PDF
  VIDEO
}

// ─── MENSAJERÍA ───────────────────────────────────────────────────────────────

model Conversacion {
  id              String    @id @default(cuid())
  participanteAId String
  participanteBId String
  participanteA   Usuario   @relation("ConvParticipanteA", fields: [participanteAId], references: [id])
  participanteB   Usuario   @relation("ConvParticipanteB", fields: [participanteBId], references: [id])
  ultimoMensaje   String?
  ultimoMensajeEn DateTime?
  noLeidosA       Int       @default(0)
  noLeidosB       Int       @default(0)
  creadaEn        DateTime  @default(now())
  mensajes        Mensaje[]

  @@unique([participanteAId, participanteBId])
  @@index([participanteAId])
  @@index([participanteBId])
  @@map("conversaciones")
}

model Mensaje {
  id             String       @id @default(cuid())
  conversacionId String
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  remitenteId    String
  remitente      Usuario      @relation("MensajesEnviados", fields: [remitenteId], references: [id])
  contenido      String
  leido          Boolean      @default(false)
  creadoEn       DateTime     @default(now())

  @@map("mensajes")
  @@index([conversacionId, creadoEn])
}

// ─── ANUNCIOS ─────────────────────────────────────────────────────────────────

model Anuncio {
  id          String   @id @default(cuid())
  titulo      String
  imagenUrl   String
  linkUrl     String?
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  creadoPorId String
  creadoEn    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("anuncios")
}

// Guarda los tokens OAuth de Classroom por usuario (admin/docente)
model ClassroomToken {
  id           String   @id @default(cuid())
  usuarioId    String   @unique
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime
  scope        String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("classroom_tokens")
}

// Clase sincronizada desde Google Classroom
model ClassroomClase {
  id             String   @id @default(cuid())
  googleCourseId String   @unique  // ID de Google Classroom
  nombre         String
  descripcion    String?
  materia        String?
  seccion        String?
  enlaceAlternativo String?         // meet link u otro
  estado         EstadoClase @default(ACTIVA)

  // Vinculación con el sistema AXIS
  grupoId        String?
  grupo          Grupo?   @relation(fields: [grupoId], references: [id])
  docenteId      String?
  docente        Usuario? @relation("ClaseDocente", fields: [docenteId], references: [id])

  // Relaciones
  eventos        ClassroomEvento[]
  grabaciones    ClassroomGrabacion[]
  tareas         ClassroomTarea[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("classroom_clases")
  @@index([docenteId])
  @@index([grupoId])
}

enum EstadoClase {
  ACTIVA
  ARCHIVADA
  ELIMINADA
}

// Evento del calendario (clase en vivo, examen, evento)
model ClassroomEvento {
  id             String      @id @default(cuid())
  googleEventId  String?     // ID del evento en Google Calendar (si se sincroniza)
  claseId        String
  clase          ClassroomClase @relation(fields: [claseId], references: [id], onDelete: Cascade)
  titulo         String
  descripcion    String?
  tipo           TipoEvento  @default(CLASE)
  fechaInicio    DateTime
  fechaFin       DateTime?
  linkMeet       String?     // link de Google Meet
  linkGrabacion  String?     // link de grabación post-evento
  completado     Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("classroom_eventos")
  @@index([claseId])
  @@index([fechaInicio])
}

enum TipoEvento {
  CLASE
  TAREA
  EXAMEN
  EVENTO
}

// Grabación de una clase (link almacenado manualmente o sincronizado)
model ClassroomGrabacion {
  id          String         @id @default(cuid())
  claseId     String
  clase       ClassroomClase @relation(fields: [claseId], references: [id], onDelete: Cascade)
  titulo      String
  descripcion String?
  linkUrl     String         // link de Drive, YouTube, Meet recording, etc.
  materia     String?
  fecha       DateTime
  duracionMin Int?
  activa      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("classroom_grabaciones")
  @@index([claseId])
  @@index([fecha])
}

// Tarea asignada desde Classroom
model ClassroomTarea {
  id               String         @id @default(cuid())
  googleWorkId     String?        @unique // ID del coursework en Google
  claseId          String
  clase            ClassroomClase @relation(fields: [claseId], references: [id], onDelete: Cascade)
  titulo           String
  descripcion      String?
  linkUrl          String?
  fechaEntrega     DateTime?
  puntosPosibles   Float?
  estado           EstadoTarea    @default(ASIGNADA)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("classroom_tareas")
  @@index([claseId])
  @@index([fechaEntrega])
}

enum EstadoTarea {
  BORRADOR
  ASIGNADA
  CERRADA
}
